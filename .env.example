# Backend environment variables — copy to .env and fill in real values
# Never commit the real .env file.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://vectorbrain:vectorbrain@localhost:5432/vectorbrain

# --- LLM (Cerebras, OpenAI-compatible) ---
# NOTE: the original spec (docs/05) called for Groq, but this build uses Cerebras
# via its OpenAI-compatible endpoint. See PROGRESS.md "Spec Deviations".
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# Verify the current model string in Cerebras's docs at build time:
# https://inference-docs.cerebras.ai/support/models
CEREBRAS_MODEL=gpt-oss-120b

# --- Embeddings ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# --- Compute device for ingestion (embeddings + Docling OCR/layout) ---
# auto = use CUDA if available, else CPU (default; works everywhere).
# cuda = force CUDA (errors if unavailable). cpu = force CPU.
# To enable GPU: install the cu124 torch wheel (see docs/08-gpu-and-ocr-plan.md
# Part C) and set DEVICE=cuda (or leave auto on a CUDA machine).
DEVICE=auto

# --- Ingestion / Chunking ---
CHUNK_MAX_TOKENS=512
TOP_K_RESULTS=6
RETRIEVAL_DISTANCE_THRESHOLD=0.5

# --- Uploads ---
MAX_UPLOAD_SIZE_MB=50
DOCUMENT_STORAGE_PATH=./storage/documents

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:5173

# --- Re-ranking (precision boost) ---
# After pgvector's broad top-k, bge-reranker-base re-scores and keeps the top N.
RERANK_TOP_N=4
